#!/bin/sh

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.js$|\.vue$')

[ -z "$FILES" ] && exit 0

echo "рЯФН Running linter..."
npx eslint $FILES

RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "вЭМ ESLint FAILED! Commit BLOCKED!"
  echo "–Ш—Б–њ—А–∞–≤—М —Г–Ї–∞–Ј–∞–љ–љ—Л–µ –њ—А–Њ–±–ї–µ–Љ—Л –Є –њ–Њ–њ—А–Њ–±—Г–є –µ—Й–µ —А–∞–Ј)"
  echo "–Ф–ї—П –њ—А–Њ–≤–µ—А–Ї–Є –Є—Б–њ–Њ–ї—М–Ј—Г–є –Ї–Њ–Љ–∞–љ–і—Г 'npm run lint'"
  echo ""
  exit 1
else
  echo "вЬЕ ESLint PASSED!. Proceeding with commit..."
  echo ""
fi

exit 0
