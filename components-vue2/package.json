{
  "name": "components-vue2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build",
    "lint": "vue-cli-service lint",
    "component": "node invalidateCache.mjs && cross-env NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build --target lib --inline-vue --mode production --name components src/main.js"
  },
  "dependencies": {
    "@sentry/vue": "^7.120.3",
    "axios": "^0.30.0",
    "bootstrap-vue": "^2.23.1",
    "config": "^4.0.0",
    "core-js": "^3.42.0",
    "dotenv": "^16.5.0",
    "js-cookie": "^3.0.5",
    "marked": "^3.0.8",
    "maska": "^1.5.2",
    "vue-custom-element": "^3.3.0",
    "vue-plugin-load-script": "^1.3.6",
    "vue-recaptcha": "^1.3.0",
    "vue2-touch-events": "^3.2.3"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "~4.5.19",
    "@vue/cli-service": "~4.5.19",
    "vue-template-compiler": "^2.7.16"
  },
  "browserslist": [
    "ios_saf >= 14 and ios_saf < 15.4",
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "npm": ">=8.5.0",
    "node": ">=16.14.0"
  }
}
